# ──────────────────────────────────────────────────────────────────
# Backend (lead ingest)
# ──────────────────────────────────────────────────────────────────
# URL base do backend Midlej (recebe POST /api/pleno-med/leads).
# Em dev pode apontar pro localhost; em prod, pro endpoint real.
BACKEND_API_URL=http://localhost:3002

# Shared secret enviado no header x-pleno-med-key em todo POST de lead.
# Obrigatório em prod (sem ele o backend devolve 401). Em dev é opcional.
PLENO_MED_INGEST_KEY=

# ──────────────────────────────────────────────────────────────────
# Analytics — APENAS LPs de Mentoria (/mentoria/*)
# ──────────────────────────────────────────────────────────────────
# Container ID do GTM da Mentoria. Formato: GTM-XXXXXXX.
# Carrega SÓ em /mentoria/* (e no subdomínio education.midlejcapital.com.br
# quando ele apontar pra cá). A landing original Pleno Med (/) NÃO tem
# analytics — escopo deliberado, configurado em app/mentoria/layout.tsx.
#
# GA4 (G-XXXXXXXXXX) deve ser configurado DENTRO do GTM como tag de
# configuração GA4 — não duplicar gtag direto no código.
NEXT_PUBLIC_MENTORIA_GTM_ID=
